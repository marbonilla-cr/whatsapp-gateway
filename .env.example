# Server
PORT=3000
NODE_ENV=development

# Admin
ADMIN_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Encryption key para los Meta Access Tokens guardados en DB
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_ENCRYPTION_KEY=64-char-hex-string-aqui

# Meta webhook verification token (lo definís vos, lo ponés en Meta Dashboard)
META_VERIFY_TOKEN=otro-secreto-aleatorio

# Meta App Secret (HMAC webhook). Opcional en dev: si falta, se usa GATEWAY_ENCRYPTION_KEY como fallback.
# META_APP_SECRET=
# Meta App ID (requerido para exchange/refresh de tokens OAuth en servicios Meta)
# META_APP_ID=
# Intervalo mínimo entre llamadas a Graph API (ms) para rate-limiting cliente Meta
# META_API_MIN_INTERVAL_MS=100

# === Postgres ===
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Redis (para BullMQ - se usa en P3) ===
REDIS_URL=redis://default:pass@host:6379

# === Tenants (bootstrap super admin — P6) ===
SUPER_ADMIN_EMAIL=admin@mbcsoft.com
SUPER_ADMIN_PASSWORD_BOOTSTRAP=cambiar-en-primer-login

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# === Meta integration tests (opcional, solo local) ===
# META_INTEGRATION_TEST=false
# META_TEST_ACCESS_TOKEN=
# META_TEST_WABA_ID=
# META_TEST_PHONE_NUMBER_ID=
# META_TEST_TO_NUMBER=
