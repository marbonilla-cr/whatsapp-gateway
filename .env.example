# Server
PORT=3000
NODE_ENV=development

# Admin
ADMIN_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# JWT (admin panel P6 — requerido en producción)
JWT_ACCESS_SECRET=__changeme_access_min_16_chars__
JWT_REFRESH_SECRET=__changeme_refresh_min_16_chars__
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# Encryption key para los Meta Access Tokens guardados en DB
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_ENCRYPTION_KEY=64-char-hex-string-aqui

# Meta webhook verification token (lo definís vos, lo ponés en Meta Dashboard)
META_VERIFY_TOKEN=otro-secreto-aleatorio

# Meta App Secret (HMAC webhook). Opcional en dev: si falta, se usa GATEWAY_ENCRYPTION_KEY como fallback.
# META_APP_SECRET=
# Meta App ID (requerido para exchange/refresh de tokens OAuth en servicios Meta)
# META_APP_ID=
# Intervalo mínimo entre llamadas a Graph API (ms) para rate-limiting cliente Meta
# META_API_MIN_INTERVAL_MS=100

# === Postgres ===
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Redis (BullMQ — P3) ===
REDIS_URL=redis://default:pass@host:6379
# Si true, rechaza POST /webhook con 403 cuando falla HMAC. Si false, solo audita (diagnóstico).
STRICT_WEBHOOK_VERIFY=true
# Timeout (ms) del POST al callbackUrl de la app vertical (worker forward)
FORWARD_TIMEOUT_MS=30000

# === Tenants (bootstrap super admin — P6) ===
SUPER_ADMIN_EMAIL=admin@mbcsoft.com
SUPER_ADMIN_PASSWORD_BOOTSTRAP=cambiar-en-primer-login

# === API v1 (apps verticales) ===
# Auth de /v1/* usa Authorization: Bearer wgw_<prefix>_<secret>
# /send legacy sigue usando X-Gateway-Key temporalmente.

# === Meta Embedded Signup (P5) ===
# Valores desde Meta for Developers tras App Review / Tech Provider
META_APP_ID=1288462783222737
META_APP_SECRET=__changeme__
META_EMBEDDED_SIGNUP_CONFIG_ID=__changeme__
META_REDIRECT_URI=https://gateway.mbcsoftcr.com/onboard/callback
# URL pública del admin para redirects post-callback (opcional; si falta se infiere del host de META_REDIRECT_URI)
# ADMIN_PUBLIC_URL=https://gateway.mbcsoftcr.com

# === Notifications (P5) ===
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
ALERT_EMAIL_FROM=alerts@mbcsoftcr.com
ALERT_EMAIL_TO=marcelo@mbcsoftcr.com

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# === Meta integration tests (opcional, solo local) ===
# META_INTEGRATION_TEST=false
# META_TEST_ACCESS_TOKEN=
# META_TEST_WABA_ID=
# META_TEST_PHONE_NUMBER_ID=
# META_TEST_TO_NUMBER=
