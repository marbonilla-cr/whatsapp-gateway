{
  "name": "whatsapp-gateway",
  "version": "1.0.0",
  "description": "Centralized gateway between Meta WhatsApp Cloud API and client applications",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:admin && npm run build:gateway && npm run copy:admin-ui",
    "build:gateway": "tsc",
    "build:admin": "npm ci --prefix admin && VITE_GATEWAY_URL= npm run build --prefix admin",
    "copy:admin-ui": "node scripts/copy-admin-ui.js",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:check": "drizzle-kit check",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"*.{ts,json,mjs}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
